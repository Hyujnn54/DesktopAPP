clean: compiler_clean 
	-$(DEL_FILE) debug\connection.o debug\employee.o debug\imageDelegate.o debug\main.o debug\mainwindow.o debug\sign.o debug\updateemployeedialog.o debug\qrc_resources.o debug\qrc_qmake_qmake_qm_files.o debug\moc_imageDelegate.o debug\moc_mainwindow.o debug\moc_sign.o debug\moc_updateemployeedialog.o

distclean: clean 
	-$(DEL_FILE) .qmake.stash
	-$(DEL_FILE) $(DESTDIR_TARGET)
	-$(DEL_FILE) Makefile.Debug

mocclean: compiler_moc_header_clean compiler_moc_objc_header_clean compiler_moc_source_clean

mocables: compiler_moc_header_make_all compiler_moc_objc_header_make_all compiler_moc_source_make_all

check: first

benchmark: first

compiler_lrelease_make_all: debug/testing_fr_TN.qm
compiler_lrelease_clean:
	-$(DEL_FILE) debug\testing_fr_TN.qm
debug/testing_fr_TN.qm: ../../testing_fr_TN.ts
	C:\Qt\6.7.3\mingw_64\bin\lrelease.exe ..\..\testing_fr_TN.ts -qm debug\testing_fr_TN.qm

compiler_no_pch_compiler_make_all:
compiler_no_pch_compiler_clean:
compiler_rcc_make_all: debug/qrc_resources.cpp debug/qrc_qmake_qmake_qm_files.cpp
compiler_rcc_clean:
	-$(DEL_FILE) debug\qrc_resources.cpp debug\qrc_qmake_qmake_qm_files.cpp
debug/qrc_resources.cpp: ../../resources.qrc \
		C:/Qt/6.7.3/mingw_64/bin/rcc.exe \
		../../bg.png
	C:\Qt\6.7.3\mingw_64\bin\rcc.exe -name resources --no-zstd ..\..\resources.qrc -o debug\qrc_resources.cpp

debug/qrc_qmake_qmake_qm_files.cpp: debug/qmake_qmake_qm_files.qrc \
		C:/Qt/6.7.3/mingw_64/bin/rcc.exe \
		debug/testing_fr_TN.qm
	C:\Qt\6.7.3\mingw_64\bin\rcc.exe -name qmake_qmake_qm_files --no-zstd debug\qmake_qmake_qm_files.qrc -o debug\qrc_qmake_qmake_qm_files.cpp

compiler_moc_predefs_make_all: debug/moc_predefs.h
compiler_moc_predefs_clean:
	-$(DEL_FILE) debug\moc_predefs.h
debug/moc_predefs.h: C:/Qt/6.7.3/mingw_64/mkspecs/features/data/dummy.cpp
	g++ -fno-keep-inline-dllexport -g -std=gnu++1z -Wall -Wextra -Wextra -dM -E -o debug\moc_predefs.h C:\Qt\6.7.3\mingw_64\mkspecs\features\data\dummy.cpp

compiler_moc_header_make_all: debug/moc_imageDelegate.cpp debug/moc_mainwindow.cpp debug/moc_sign.cpp debug/moc_updateemployeedialog.cpp
