     <property name="styleSheet">
      <string notr="true">/* General Styles */
* {
    font-family: Arial, sans-serif;
}

/* Styling for the main background */
QWidget {
    background-color: #2C3E50; /* Dark gray-blue */
    color: white;
}

/* Styling for labels */
QLabel {
    color: white;
    font-size: 15px;
}

/* Styling for input fields */
QLineEdit, QComboBox, QDateEdit {
    background-color: #34495E; /* Slightly lighter blue */
    color: white;
    border: 1px solid #5DADE2; /* Blue border */
    padding: 6px;
    border-radius: 5px;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border: 1px solid #3498DB; /* Brighter blue when focused */
}

/* Styling for Date Picker (QDateEdit) */
QDateEdit::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: right;
    width: 20px;
    border-left: 1px solid #5DADE2;
}

QDateEdit::down-arrow {
    image: url(:/icons/calendar.png); /* Replace with actual icon path */
    width: 16px;
    height: 16px;
}

/* Styling for Dropdown (Gender Selection) */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: right;
    width: 20px;
    border-left: 1px solid #5DADE2;
}

QComboBox::down-arrow {
    image: url(:/icons/dropdown.png); /* Replace with actual icon */
    width: 14px;
    height: 14px;
}

/* Styling for Buttons */
QPushButton {
    background-color: #5DADE2; /* Soft blue */
    color: white;
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 15px;
    font-weight: bold;
    border: none;
}

QPushButton:hover {
    background-color: #3498DB; /* Brighter blue on hover */
}

/* Special Styling for Add &amp; List Buttons */
QPushButton#btnAdd {
    background-color: #2ECC71; /* Green for adding */
}

QPushButton#btnAdd:hover {
    background-color: #27AE60; /* Darker green on hover */
}

QPushButton#btnList {
    background-color: #E67E22; /* Orange for listing */
}

QPushButton#btnList:hover {
    background-color: #D35400; /* Darker orange on hover */
}

/* Employee List Styling */
QTableView, QListWidget {
    background-color: #34495E;
    border: 1px solid #5DADE2;
    color: white;
    selection-background-color: #5DADE2;
    alternate-background-color: #2D3E50;
}

QTableView::item:hover, QListWidget::item:hover {
    background-color: #5DADE2;
    color: black;
}

/* Table Header */
QHeaderView::section {
    background-color: #5DADE2;
    color: white;
    padding: 6px;
    border: 1px solid #2C3E50;
}
</string>
