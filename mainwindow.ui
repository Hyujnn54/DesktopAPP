  <property name="styleSheet">
   <string notr="true">/* Global Styles */
background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 rgba(163, 230, 255, 255), stop:1 rgba(255, 255, 255, 255));
QWidget {
    background-color:#qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1,
 stop:0 rgba(163, 230, 255, 255), 
stop:1 rgba(255, 255, 255, 255)); 
    color: white;
    font-size: 16px;
}

/* Labels */
QLabel {
    color: white;
    font-size: 18px;
    font-weight: bold;
}

/* Input Fields */
QLineEdit, QDateEdit, QComboBox {
    background-color: transparent;
    color: black;
    border: 1px solid #5DADE2;
    padding: 6px;
    border-radius: 5px;
    font-size: 16px;
}

/* Buttons */


/* Icons for Specific Fields */
QLineEdit#cinField { background-image: url('icons/id.png'); background-position: left center; background-repeat: no-repeat; padding-left: 30px; }
QLineEdit#emailField { background-image: url('icons/email.png'); background-position: left center; background-repeat: no-repeat; padding-left: 30px; }
QLineEdit#phoneField { background-image: url('icons/phone.png'); background-position: left center; background-repeat: no-repeat; padding-left: 30px; }

/* Dropdown Buttons */
QPushButton#addEmployeeButton, QPushButton#listEmployeeButton {
    background-color: #5DADE2;
    border-radius: 10px;
    padding: 10px;
    font-size: 18px;
}

QPushButton#addEmployeeButton::after, QPushButton#listEmployeeButton::after {
    content: '\25BC'; /* Downward Arrow for Dropdown */
    color: white;
    font-size: 18px;
    padding-left: 8px;
}
</string>
